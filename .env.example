# ── Server ────────────────────────────────────────────────────────────────────
# PORT is set automatically by Render (default 10000); override locally only.
PORT=8000

# Gunicorn / uvicorn log verbosity: debug | info | warning | error | critical
LOG_LEVEL=info

# Number of gunicorn worker processes.
# Each worker loads ~400 MB of models (spaCy + sentence-transformers + LanguageTool JVM).
# Keep at 1 on Render free tier (512 MB RAM). Raise to 2–4 on paid plans.
WEB_CONCURRENCY=1

# ── Future: Authentication ────────────────────────────────────────────────────
# Uncomment and populate when you add API key auth to the /score endpoint.
# API_KEY=your-secret-key-here

# ── Future: CORS ──────────────────────────────────────────────────────────────
# Replace * with your frontend origin once it's known.
# CORS_ORIGINS=https://your-frontend.vercel.app
